{
  "name": "@rocicorp/logger",
  "description": "Logging utilities",
  "version": "5.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rocicorp/logger.git"
  },
  "license": "Apache-2.0",
  "scripts": {
    "test": "vitest run src/",
    "test:watch": "vitest src/",
    "format": "oxfmt src/",
    "check-format": "oxfmt --check src/",
    "lint": "eslint src/",
    "build": "rm -rf out && tsc",
    "prepack": "pnpm run format && pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.49.0",
    "oxfmt": "^0.54.0",
    "typescript": "^5.8.3",
    "vitest": "3.1.1"
  },
  "type": "module",
  "types": "out/logger.d.ts",
  "module": "out/logger.js",
  "main": "out/logger.js",
  "exports": {
    ".": "./out/logger.js"
  },
  "files": [
    "out/*",
    "!out/*.test.*"
  ],
  "packageManager": "pnpm@11.1.3"
}
